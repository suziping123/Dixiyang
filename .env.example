# ========================
# Dixiyang 环境变量配置
# ========================
# 复制此文件为 .env 并填入你自己的值
# cp .env.example .env

# --- 数据库（MySQL）---
DB_USERNAME=root
DB_PASSWORD=your_password_here
DATABASE_URL=mysql+pymysql://root:your_password_here@127.0.0.1:3306/dixiyang?charset=utf8

# --- 邮件（QQ SMTP，可选）---
# MAIL_USERNAME=your-qq-number@qq.com
# MAIL_PASSWORD=your-smtp-authorization-code

# --- JWT 密钥（必须）---
# 生成方法：openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here

# --- DeepSeek API（必须）---
# 从 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=sk-your-api-key-here

# --- Qdrant 向量数据库（可选）---
# QDRANT_API_KEY=your-qdrant-api-key
