# ========================
# Dixiyang 环境变量配置
# ========================
# 复制此文件为 .env 并填入你自己的值
# cp .env.example .env

# --- 数据库 ---
DB_USERNAME=root
DB_PASSWORD=your_password_here

# --- DeepSeek API ---
# 从 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=sk-your-api-key-here

# --- Qdrant 向量数据库（可选，暂时禁用）---
# QDRANT_API_KEY=your-qdrant-api-key
